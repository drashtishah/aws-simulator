{
  "CacheParameterGroupName": "trellis-redis-params",
  "CacheParameterGroupFamily": "redis7",
  "Description": "Custom parameter group for Trellis Health production Redis",
  "IsGlobal": false,
  "ARN": "arn:aws:elasticache:us-east-1:123456789012:parametergroup:trellis-redis-params",
  "Parameters": [
    {
      "ParameterName": "maxmemory-policy",
      "ParameterValue": "noeviction",
      "Description": "The eviction policy for keys when maximum memory is reached",
      "Source": "user",
      "DataType": "string",
      "AllowedValues": "volatile-lru,allkeys-lru,volatile-lfu,allkeys-lfu,volatile-random,allkeys-random,volatile-ttl,noeviction",
      "IsModifiable": true,
      "MinimumEngineVersion": "2.8.6",
      "ChangeType": "immediate"
    },
    {
      "ParameterName": "maxmemory-samples",
      "ParameterValue": "5",
      "Description": "Number of keys to sample when evicting",
      "Source": "system",
      "DataType": "integer",
      "IsModifiable": true,
      "MinimumEngineVersion": "2.8.6",
      "ChangeType": "immediate"
    },
    {
      "ParameterName": "timeout",
      "ParameterValue": "0",
      "Description": "Close connection after client is idle for N seconds (0 to disable)",
      "Source": "system",
      "DataType": "integer",
      "IsModifiable": true,
      "MinimumEngineVersion": "2.8.6",
      "ChangeType": "immediate"
    },
    {
      "ParameterName": "tcp-keepalive",
      "ParameterValue": "300",
      "Description": "TCP keepalive interval in seconds",
      "Source": "system",
      "DataType": "integer",
      "IsModifiable": true,
      "MinimumEngineVersion": "2.8.6",
      "ChangeType": "immediate"
    },
    {
      "ParameterName": "activedefrag",
      "ParameterValue": "no",
      "Description": "Enable active defragmentation",
      "Source": "system",
      "DataType": "string",
      "IsModifiable": true,
      "MinimumEngineVersion": "4.0.0",
      "ChangeType": "immediate"
    },
    {
      "ParameterName": "hz",
      "ParameterValue": "10",
      "Description": "Server background tasks frequency",
      "Source": "system",
      "DataType": "integer",
      "IsModifiable": true,
      "MinimumEngineVersion": "2.8.6",
      "ChangeType": "immediate"
    }
  ]
}
