{
  "TaskDefinition": {
    "family": "cleanup-scratch",
    "taskRoleArn": "arn:aws:iam::112233445566:role/cleanup-scratch-task-role",
    "executionRoleArn": "arn:aws:iam::112233445566:role/ecs-task-execution",
    "networkMode": "awsvpc",
    "containerDefinitions": [
      {
        "name": "cleanup",
        "image": "112233445566.dkr.ecr.us-east-2.amazonaws.com/drifter-cleanup-scratch:v3.1",
        "essential": true,
        "environment": [
          { "name": "MEMORYDB_ENDPOINT", "value": "clustercfg.drifter-memorydb-cluster.abcdef.memorydb.us-east-2.amazonaws.com" },
          { "name": "MEMORYDB_PORT", "value": "6379" },
          { "name": "MEMORYDB_USERNAME", "value": "drifter-app" },
          { "name": "MEMORYDB_DB", "value": "5" },
          { "name": "CLEANUP_COMMAND", "value": "FLUSHDB" }
        ],
        "logConfiguration": {
          "logDriver": "awslogs",
          "options": {
            "awslogs-group": "/ecs/drifter/cleanup-scratch",
            "awslogs-region": "us-east-2"
          }
        }
      }
    ],
    "cpu": "256",
    "memory": "512"
  },
  "EventBridgeSchedule": {
    "Name": "cleanup-scratch-nightly",
    "ScheduleExpression": "cron(0 2 * * ? *)",
    "Description": "Run cleanup-scratch ECS task every night at 02:00 UTC to clear the pre-aggregation scratch database.",
    "State": "ENABLED",
    "TargetArn": "arn:aws:ecs:us-east-2:112233445566:cluster/drifter-prod",
    "RoleArn": "arn:aws:iam::112233445566:role/eventbridge-to-ecs-role"
  },
