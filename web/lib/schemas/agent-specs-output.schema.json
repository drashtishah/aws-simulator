{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aws-simulator.local/schemas/agent-specs-output.schema.json",
  "title": "test agent --json output",
  "description": "Shape of the JSON document printed by `test agent --json` and `test agent --dry-run --json`. Derived from observed CLI output on 2026-04-08.",
  "type": "object",
  "required": ["command", "ts", "specs", "verdict"],
  "properties": {
    "command": {
      "type": "string",
      "const": "agent"
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "specs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file", "name", "steps", "valid"],
        "properties": {
          "file": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "steps": { "type": "integer", "minimum": 0 },
          "valid": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["VALID", "INVALID", "PASS", "FAIL"]
    }
  },
  "additionalProperties": true
}
