{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aws-simulator.local/schemas/persona-finding.schema.json",
  "title": "Persona exploration finding file",
  "description": "Shape of a single file under web/test-results/personas/<persona-id>-<timestamp>.json, consumed by `sim-test personas --feedback`. Derived from the PersonaResultData and PersonaFinding interfaces in scripts/sim-test.ts on 2026-04-08.",
  "type": "object",
  "required": ["persona", "findings"],
  "properties": {
    "persona": {
      "type": "string",
      "description": "Persona id, for example 'hostile-user' or 'impatient-beginner'.",
      "minLength": 1
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of the run. Optional; when absent, --feedback uses today's date."
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "category", "description"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "reproduction": {
            "type": "string"
          },
          "suggested_guardrail": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
