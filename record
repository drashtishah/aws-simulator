#!/bin/bash
# Records a terminal session. Start claude and /play inside.
# Type 'exit' when done. Cast file saves to learning/recordings/.

set -euo pipefail

TIMESTAMP=$(date +%Y%m%d_%H%M%S)
RECORDING_DIR="learning/recordings"
CAST_FILE="${RECORDING_DIR}/${TIMESTAMP}.cast"

mkdir -p "$RECORDING_DIR"

if ! command -v asciinema &>/dev/null; then
  echo "Missing: asciinema"
  echo "  macOS:         brew install asciinema"
  echo "  Ubuntu/Debian: sudo apt install asciinema"
  exit 1
fi

echo "------------------------------------"
echo "  Recording started."
echo "  Everything below this is recorded."
echo "  Type 'exit' when done."
echo "------------------------------------"

asciinema rec "$CAST_FILE" \
  --cols 110 \
  --rows 40

echo "------------------------------------"
echo "  Done: $CAST_FILE"
echo "------------------------------------"
