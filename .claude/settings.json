{
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "event": "Stop",
            "command": "npx tsx .claude/hooks/stop-journal-check.ts",
            "cwd": "/Users/drashti/experiments/aws-simulator",
            "timeout": 5000,
            "allowed_tools": [
              "Read"
            ]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Task",
        "hooks": [
          {
            "type": "command",
            "event": "PostToolUse",
            "command": "npx tsx .claude/hooks/emotion-check.ts",
            "cwd": "/Users/drashti/experiments/aws-simulator",
            "timeout": 3000,
            "allowed_tools": [
              "Read",
              "Write"
            ]
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "event": "PostToolUse",
            "command": "npx tsx .claude/hooks/post-commit-note-check.ts",
            "cwd": "/Users/drashti/experiments/aws-simulator",
            "timeout": 5000,
            "allowed_tools": [
              "Read"
            ]
          }
        ]
      }
    ]
  }
}
