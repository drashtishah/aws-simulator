{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Bash",
      "Agent",
      "mcp__aws-knowledge-mcp-server",
      "mcp__chrome-devtools",
      "Skill(schedule)",
      "Edit(/Users/drashti/experiments/aws-simulator/.claude/skills/**)",
      "Edit(/Users/drashti/experiments/aws-simulator/.claude/worktrees/**)",
      "Edit(/Users/drashti/experiments/aws-simulator/CLAUDE.md)",
      "Edit(/Users/drashti/experiments/aws-simulator/references/**)",
      "Write(/Users/drashti/experiments/aws-simulator/.claude/skills/**)",
      "Write(/Users/drashti/experiments/aws-simulator/.claude/worktrees/**)",
      "Write(/Users/drashti/experiments/aws-simulator/CLAUDE.md)",
      "Write(/Users/drashti/experiments/aws-simulator/references/**)"
    ]
  },
  "enabledMcpjsonServers": [
    "aws-knowledge-mcp-server",
    "chrome-devtools"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/guard-write.ts"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/git-discipline-reminder.ts"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/pre-commit-issues.ts"
          },
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/pre-commit-self-audit.ts"
          },
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/pre-commit-ui-tests.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/log-hook.ts"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/plan-exit-reminder.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/log-hook.ts"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/log-hook.ts"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/log-hook.ts"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/log-hook.ts"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/log-hook.ts"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/log-hook.ts"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/log-hook.ts"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/log-hook.ts"
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/log-hook.ts"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/log-hook.ts"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/log-hook.ts"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx .claude/hooks/log-hook.ts"
          }
        ]
      }
    ]
  }
}
