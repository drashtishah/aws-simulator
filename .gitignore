# Player data per-user (profile, sessions, logs, player vault); system vault tracked (Issue #171)
learning/*
!learning/system-vault/

# Node dependencies
node_modules/

# All logs (shared hooks + web app)
learning/logs/

# Vault raw notes (temporary, compiled by play skill)
learning/player-vault/raw/
learning/logs/activity-archive-*.jsonl
.web-active.lock

# Test artifacts (screenshots, traces from failed tests)
web/test/e2e/test-results/

# Per-test scratch dirs (PR-A.4.1: AWS_SIMULATOR_SESSIONS_DIR override target)
web/test/.tmp/

# test output
web/test-results/

# Runtime skill state
.claude/state/

# Local docs and plans
docs/
.claude/plans/

# TypeScript build output
dist/

# mypy cache (legacy; redirected to .tmp/mypy-cache in npm test)
.mypy_cache/

# Scratch scoped to tooling (mypy cache redirect target, etc.)
.tmp/

# Git worktrees
.worktrees/
.claude/worktrees/
# Explicit per-worktree progress log rule (redundant with .claude/worktrees/
# above, but kept explicit per Issue #138 acceptance criteria).
.claude/worktrees/**/progress.txt

# Auto-generated path registry (regenerated by extract_paths.py via postinstall + npm test)
references/registries/path-registry.csv

# Auto-generated permission bypass registry (regenerated by audit-permissions.ts via postinstall + npm test)
references/registries/permission-bypass-registry.md
