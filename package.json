{
  "name": "aws-incident-simulator",
  "version": "1.0.0",
  "scripts": {
    "start": "node web/server.js",
    "dev": "NODE_ENV=development node web/server.js",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.frontend.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.frontend.json",
    "test": "python3 scripts/extract_paths.py && tsx scripts/sim-test.js run",
    "test:agent": "tsx scripts/sim-test.js agent",
    "test:personas": "tsx scripts/sim-test.js personas",
    "test:evals": "tsx scripts/sim-test.js evals",
    "test:validate": "tsx scripts/sim-test.js validate",
    "test:summary": "tsx scripts/sim-test.js summary",
    "test:content": "tsx scripts/sim-test.js content",
    "extract-paths": "python3 scripts/extract_paths.py",
    "health": "tsx scripts/code-health.js",
    "feedback:personas": "tsx scripts/sim-test.js personas --feedback",
    "audit:permissions": "tsx scripts/audit-permissions.js",
    "generate-index": "tsx scripts/generate-agent-index.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.91",
    "express": "^4.21.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "acorn": "^8.16.0",
    "commander": "^12.1.0",
    "connect-livereload": "^0.6.1",
    "livereload": "^0.10.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
