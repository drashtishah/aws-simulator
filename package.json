{
  "name": "aws-incident-simulator",
  "version": "1.0.0",
  "scripts": {
    "start": "tsc -p tsconfig.frontend.json && tsx web/server.ts",
    "dev": "tsc -p tsconfig.frontend.json && NODE_ENV=development tsx web/server.ts",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.frontend.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.frontend.json",
    "test": "python3 scripts/extract_paths.py && mypy --strict scripts/extract_paths.py && npm run typecheck && tsx scripts/sim-test.ts run",
    "test:file": "tsx --test --test-force-exit",
    "test:agent": "tsx scripts/sim-test.ts agent",
    "test:personas": "tsx scripts/sim-test.ts personas",
    "test:evals": "tsx scripts/sim-test.ts evals",
    "test:validate": "tsx scripts/sim-test.ts validate",
    "test:summary": "tsx scripts/sim-test.ts summary",
    "test:content": "tsx scripts/sim-test.ts content",
    "extract-paths": "python3 scripts/extract_paths.py",
    "doctor": "tsx scripts/doctor.ts",
    "health": "tsx scripts/code-health.ts",
    "feedback:personas": "tsx scripts/sim-test.ts personas --feedback",
    "audit:permissions": "tsx scripts/audit-permissions.ts",
    "install-git-hooks": "tsx scripts/install-git-hooks.ts",
    "run-plans": "./scripts/run-plans.sh",
    "postinstall": "tsx scripts/install-git-hooks.ts && python3 scripts/extract_paths.py",
    "build-agent-index": "tsx scripts/build-agent-index.ts",
    "agent-browser-summary": "tsx scripts/agent-browser-summarize.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.91",
    "express": "^4.21.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "acorn": "^8.16.0",
    "commander": "^12.1.0",
    "connect-livereload": "^0.6.1",
    "livereload": "^0.10.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
